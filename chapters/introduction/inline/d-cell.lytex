% First line of a paragraph: baseline alignment (scoped so default vc returns after).
\begingroup
\bookInlineMusicUseBaseline
\beginBookInlineMusic
\begin{lilypond}
\version "2.24.0"
\include "lily/book-inline.ily"
\relative c' {
  \clef treble
  \key c \major
  c8 d e f g4 e
}
\end{lilypond}
\finishBookInlineMusic
\endgroup
